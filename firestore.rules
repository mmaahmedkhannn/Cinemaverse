rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // 0. System State
    match /system/{document} {
      allow read, write: if true;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && request.resource.data.keys().hasAll(['email']);
      allow update: if isOwner(userId);
      allow delete: if false; // Users shouldn't be deleted purely from firestore client
      
      // Nested collections inside users
      match /ratings/{movieId} {
        allow read, write: if isOwner(userId);
      }
      match /watchlist/{movieId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Battles Collection (Global Voting)
    match /battles/{battleId} {
      // Anyone can read public battles
      allow read: if true;
      
      // Creating a new battle requires auth (lazy init by first visitor)
      allow create: if isAuthenticated() && request.resource.data.movie1Votes == 0 && request.resource.data.movie2Votes == 0;
      
      // Incrementing existing battle votes
      allow update: if true;

      // A user's vote record on this specific battle
      match /votes/{userId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // 3. Top100 Global Votes
    match /top100votes/{movieId} {
      allow read: if true;
      
      match /votes/{userId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

  }
}
