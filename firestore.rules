rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // 0. System Config
    match /system/{document} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.keys().hasAll(['email']);
      allow update: if isOwner(userId);
      allow delete: if false; // Users shouldn't be deleted purely from firestore client

      // Nested collections inside users
      match /ratings/{movieId} {
        allow read, write: if isOwner(userId);
      }
      match /watchlist/{movieId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Battles Collection (Open Voting — guests allowed)
    match /battles/{battleId} {
      // Anyone can read public battles
      allow read: if true;

      // Anyone can create a new battle (lazy init by first voter)
      allow create: if request.resource.data.movie1Votes == 0 && request.resource.data.movie2Votes == 0;

      // Anyone can increment vote counts securely
      allow update: if (
      (request.resource.data.movie1Votes == resource.data.movie1Votes + 1 && request.resource.data.movie2Votes == resource.data.movie2Votes) ||
      (request.resource.data.movie2Votes == resource.data.movie2Votes + 1 && request.resource.data.movie1Votes == resource.data.movie1Votes)
      );

      // Vote records — anyone can read/write their own vote (uses guestId or userId)
      match /votes/{odv} {
        allow read, write: if true;
      }
    }

    // 3. Top100 Global Votes
    match /top100votes/{movieId} {
      allow read: if true;

      match /votes/{userId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

  }
}
